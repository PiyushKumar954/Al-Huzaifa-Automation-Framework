	 @FindBy(xpath = "//footer")
	 WebElement footerSection;
	 	public void scrollToFooter() {
	        ((JavascriptExecutor) driver).executeScript("arguments[0].scrollIntoView({block:'center'});", footerSection);
	        waitForVisible(footerSection);
	    }

	    public boolean isFooterVisible() {
	    	scrollToFooter();
	        return isDisplayed(footerSection);
	    }
	    
