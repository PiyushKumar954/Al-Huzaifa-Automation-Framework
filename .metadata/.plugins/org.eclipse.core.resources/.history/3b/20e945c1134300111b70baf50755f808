package TestCase;

import org.testng.Assert;
import org.testng.annotations.Test;

import PageObject.Footer;
import TestBase.BaseClass;
import Utilities.ExtentReportManager;

public class TC002_Footer extends BaseClass{
	
	@Test(groups = {"Sanity"})
    public void FooterSectionValidation()
    {
		Footer footer = new Footer(driver);

        logger.info("Verifying Footer section visibility");
        ExtentReportManager.test.info("TC002 Footer Sanity -> Footer section visibility");

        Assert.assertTrue(footer.isFooterVisible(), "Footer section is not visible");
        ExtentReportManager.test.info("TC002 Footer Sanity -> Footer section is Visible");
        
        Assert.assertTrue(footer.isFooterLogoVisible(), "Footer logo is not visible");
        ExtentReportManager.test.info("TC002 Footer Sanity -> Footer logo is visible");
        
        Assert.assertTrue(footer.isCompanyNameVisible(), "Company name is not visible");
        ExtentReportManager.test.info("TC002 Footer Sanity -> Company name is visible");
        
        Assert.assertTrue(footer.isCompanyLocationVisible(), "Company location is not visible");
        ExtentReportManager.test.info("TC002 Footer Sanity -> Company Location is visible");
        
        Assert.assertTrue(footer.isEmailVisible(), "Email is not visible");
        ExtentReportManager.test.info("TC002 Footer Sanity -> Email is visible");
        
        Assert.assertTrue(footer.isLandlineVisible(), "Landline number is not visible");
        ExtentReportManager.test.info("TC002 Footer Sanity -> Landline number is visible");
        
        Assert.assertTrue(footer.isMobileVisible(), "Mobile number is not visible");
        ExtentReportManager.test.info("TC002 Footer Sanity -> Mobile number is visible");
        
        Assert.assertTrue(footer.isFacebookVisible(), "Facebook icon is not visible");
        ExtentReportManager.test.info("TC002 Footer Sanity ->  Facebook Icon is visible");
        
        Assert.assertTrue(footer.isInstagramVisible(), "Instagram icon is not visible");
        ExtentReportManager.test.info("TC002 Footer Sanity -> Instagram Icon is visible");
        
        Assert.assertTrue(footer.isYoutubeVisible(), "YouTube icon is not visible");
        ExtentReportManager.test.info("TC002 Footer Sanity -> Youtube Icon is visible");
        
        Assert.assertTrue(footer.isCopyrightVisible(), "Copyright text is not visible");
        ExtentReportManager.test.info("TC002 Footer Sanity -> Copyright content is visible");
        
        logger.info("Footer static content validation passed");
    }

}
