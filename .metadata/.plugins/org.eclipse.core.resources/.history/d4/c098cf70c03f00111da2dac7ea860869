package TestCase;

import org.testng.Assert;
import org.testng.annotations.Test;

import PageObject.Header;
import TestBase.BaseClass;
 public class TC001_Header extends BaseClass{
	
	@Test(groups = {"Free Shipping"})
    public void FreeShipping()
    {
        Header header = new Header(driver);

        logger.info("Verifying free shipping validation in Header");

        Assert.assertTrue(header.isFreeShippingVisible(), "Free Shipping option is not visible in header");
        logger.info("Free Shipping is visible in header");
        
        String actualText = header.getFreeShippingText();
        Assert.assertTrue(
            actualText.contains("Free delivery on all online orders above 500 AED"),
            "Expected text is not displayed. Actual text: " + actualText );
       logger.info("Free Shipping text validation passed");
       System.out.println(actualText);
    }
	
