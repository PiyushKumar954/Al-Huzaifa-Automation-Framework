package TestCase;

import java.time.Duration;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.interactions.Actions;
import org.testng.Assert;

public class CodeRun {
	public static void main(String[] args) throws InterruptedException {
        WebDriver driver = new ChromeDriver();
        driver.manage().window().maximize();
        driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(10));
        driver.get("https://www.alhuzaifa.com/en/");
        WebElement closePopup = driver.findElement(
        	    By.xpath("//button[@type='button' and contains(@class,'absolute') and contains(@class,'right-2.5')]")
        	);
        closePopup.click();
        System.out.println("Welcome popup closed");
        
        WebElement UAE= driver.findElement(By.xpath("(//span[contains(text(),'UAE')])[2]"));
        Actions actions = new Actions(driver);
        actions.moveToElement(UAE).perform();
       
        driver.findElement(By.xpath("(//span[contains(text(),'KSA')])[2]")).click();
        String KSAURL = driver.getCurrentUrl();
        System.out.println(KSAURL);
        Assert.assertTrue( KSAURL.contains("https://www.alhuzaifa.com/sa-en/"),
        	    "Landing page URL is not matching after clicking. Actual URL: " + KSAURL);
        
        
        WebElement KSA= driver.findElement(By.xpath("(//span[contains(text(),'KSA')])[2]"));
        Actions actions1 = new Actions(driver);
        actions1.moveToElement(KSA).perform();driver.findElement(By.xpath("(//span[contains(text(),'QATAR')])[2]")).click();
        String QatarURL = driver.getCurrentUrl();
        System.out.println(QatarURL);
        Assert.assertTrue( QatarURL.contains("https://www.alhuzaifa.com/qa-en/"),
        	    "Landing page URL is not matching after clicking. Actual URL: " + QatarURL);
        driver.quit();
    }

}
