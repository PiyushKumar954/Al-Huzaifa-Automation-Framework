@Test(dataProvider="LoginCredentials", dataProviderClass=DataProviders.class)
public void Signin(String Username, String Password, String Validity) {
    logger.info("*** Starting TC003 Signin Validation ***");
    logger.info("Test data from sheet -> Email: {}", Username);
    logger.info("Test data from sheet -> Password: {}", Password);
    logger.info("Test data from sheet -> Validity: {}", Validity);

    try {
        Header header = new Header(driver);
        header.Signin();
        logger.info("*** Clicked on Signin Button ***");

        SignIn signin = new SignIn(driver);
        logger.info("*** User is on Login Page ***");

        signin.EnterEmail(Username);
        signin.EnterPassword(Password);
        signin.ClickSignin();

        if (Validity.equalsIgnoreCase("Valid")) {
            boolean loggedIn = signin.waitForSuccessfulLogin();
            Assert.assertTrue(loggedIn, "Valid login failed. User was not redirected to My Account page.");

            String actualUrl = driver.getCurrentUrl();
            Assert.assertEquals(
                actualUrl,
                "https://www.alhuzaifa.com/en/customer/account/",
                "Valid login failed. User was not redirected to My Account page."
            );

            boolean isMyAccountVisible = header.isMyAccountVisible();
            Assert.assertTrue(isMyAccountVisible, "My Account is not visible in header after valid login.");

            logger.info("*** Valid login successful. URL and My Account header validated ***");
            header.SignOut();
            logger.info("*** User signed out successfully ***");
        }
        else if (Validity.equalsIgnoreCase("Invalid")) {
            boolean loggedIn = signin.waitForSuccessfulLogin();

            if (loggedIn) {
                header.SignOut();
                Assert.fail("Invalid login passed unexpectedly.");
            }

            Assert.assertTrue(
                signin.isLoginErrorVisible(),
                "Expected error message was not displayed for invalid credentials."
            );

            String actualError = signin.getLoginErrorMessage();
            logger.info("*** Invalid login validated. Error message displayed: {} ***", actualError);
        }
        else {
            Assert.fail("Validity must be either 'Valid' or 'Invalid'");
        }
    }
    catch (Exception e) {
        logger.error("Exception during signin test", e);
        Assert.fail("Test failed due to exception: " + e.getMessage());
    }

    logger.info("*** Signin test execution completed ***");
}

